  "open_questions": [
    {
      "id": "Q1",
      "topic": "キャラクター ID / 表示名 / VoiceTone 識別子",
      "decision": "S4 全体設計で 5 キャラ（hina/airi/yuki/mio/rin）を仮確定。VoiceBOX 話者 ID は spk_01〜05 をプレースホルダーで進める。"
    },
    {
      "id": "Q2",
      "topic": "ストーリーモード章数・台詞",
      "decision": "1 キャラあたり 3 章を初期実装。台詞テキストは仮台本（res/raw/story_*.json）でバンドル。"
    },
    {
      "id": "Q3",
      "topic": "大連鎖クリップの動画形式",
      "decision": "mp4 を採用（MediaCodec H.264 + MediaMuxer）。fail 時は WebP アニメーションへフォールバックではなくスキップ（FR-5.3.3 fallback 禁止）。"
    },
    {
      "id": "Q4",
      "topic": "CPU 思考ロジックパラメータ",
      "decision": "Easy/Normal/Hard/Expert を connectivity threshold + thinkDelayMs で表現。設計書で具体値を定義。"
    },
    {
      "id": "Q5",
      "topic": "アセット（画像・音声）生成パイプライン",
      "decision": "本ループ内では Docker ComfyUI/VoiceBOX は実行せず、プレースホルダー画像（単色＋ID 文字）・無音音声（440Hz 短音）でバンドル。実アセット差替えは納品時タスクとして CHANGELOG に明記。"
    },
    {
      "id": "Q6",
      "topic": "applicationId",
      "decision": "現状 com.example.myapp を継続使用（loop.yaml と一致）。リネームは別ループ。"
    }
  ],
